    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "description": "Retard de la boucle d'événements. C'est la saturation vue de l'intérieur : quand ce chiffre grimpe, l'API n'arrive plus à traiter ce qu'on lui demande et la latence se dégrade. C'est le meilleur signal d'alerte disponible sans instrumentation HTTP — mais il indique que ça rame, pas de combien.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
