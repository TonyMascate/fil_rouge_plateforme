          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"api\"}",
          "legendFormat": "p99 — {{instance}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-main" },
          "editorMode": "code",
          "expr": "nodejs_eventloop_lag_p50_seconds{job=\"api\"}",
          "legendFormat": "p50 — {{instance}}",
          "range": true,
          "refId": "B"
